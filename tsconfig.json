{
  "extends": "@tsconfig/node24/tsconfig.json",
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
    "allowSyntheticDefaultImports": true
  },
  "include": [
    "index.ts",
    "lib/*",
    "lib/**/*"
  ]
}
